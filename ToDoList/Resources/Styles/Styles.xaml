<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandBackground}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource BrandText}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="Main" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource BrandText}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource BrandMutedText}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="Main" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="44" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="TextColor" Value="{StaticResource BrandText}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource BrandMutedText}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="Main" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="AutoSize" Value="TextChanges" />
        <Setter Property="MinimumHeightRequest" Value="96" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="Main" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="ListView">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="SeparatorVisibility" Value="None" />
    </Style>

    <Style x:Key="BrandTitle" TargetType="Label">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource BrandText}" />
    </Style>

    <Style x:Key="BrandSubtitle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource BrandMutedText}" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource BrandMutedText}" />
    </Style>

    <Style x:Key="TaskTitle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource BrandText}" />
    </Style>

    <Style x:Key="TaskBody" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource BrandMutedText}" />
    </Style>

    <Style x:Key="InputCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurfaceAlt}" />
        <Setter Property="Stroke" Value="{StaticResource BrandStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style x:Key="ResultCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurface}" />
        <Setter Property="Stroke" Value="{StaticResource BrandStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="Padding" Value="16,14" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandAccent}" />
        <Setter Property="TextColor" Value="{StaticResource BrandBackground}" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurfaceAlt}" />
        <Setter Property="TextColor" Value="{StaticResource BrandText}" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource BrandSurfaceAlt}" />
        <Setter Property="TextColor" Value="{StaticResource BrandMutedText}" />
    </Style>

</ResourceDictionary>
