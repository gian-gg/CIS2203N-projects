<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:BmiCalcMaui.Components"
             x:Class="BmiCalcMaui.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="24,32,24,24" Spacing="14">
            <Label Text="Enter values and tap Calculate"
                   Style="{StaticResource BrandSubtitle}" />

            <Border Style="{StaticResource InputCard}">
                <Picker x:Name="UnitPicker" Title="Select units">
                    <Picker.Items>
                        <x:String>Metric (cm, kg)</x:String>
                        <x:String>Imperial (in, lb)</x:String>
                    </Picker.Items>
                </Picker>
            </Border>

            <Border Style="{StaticResource InputCard}">
                <Entry x:Name="HeightEntry" Placeholder="Height (cm)" Keyboard="Numeric" />
            </Border>

            <Border Style="{StaticResource InputCard}">
                <Entry x:Name="WeightEntry" Placeholder="Weight (kg)" Keyboard="Numeric" />
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.Column="0" Text="CALCULATE" Style="{StaticResource PrimaryButton}" />
                <Button Grid.Column="1" Text="RESET" Style="{StaticResource GhostButton}" />
            </Grid>

            <Border Style="{StaticResource ResultCard}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Result" Style="{StaticResource BrandSubtitle}" />
                    <Label x:Name="BmiValueLabel" Text="--" FontSize="42" FontAttributes="Bold" />
                    <Label x:Name="BmiHintLabel"
                           Text="Healthy BMI range is about 18.5 to 24.9"
                           Style="{StaticResource BrandSubtitle}" />
                </VerticalStackLayout>
            </Border>

            <components:BmiLevelsLegend />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
